# Copy this file to .env and edit values as needed. Values here are examples.

# Scraping 
# The YouTube video URL(s) to scrape comments from.
# You can provide multiple URLs separated by commas.
# Example format: https://www.youtube.com/watch?v=<VIDEO_ID>, https://youtu.be/<VIDEO_ID>
VIDEO_URL=https://www.youtube.com/watch?v=dQw4w9WgXcQ,https://youtu.be/iEGP711wYF8

# Maximum number of comments to collect per video (integer).
TARGET_COMMENT=200

# Number of comments per split file. Default is 100. Set to an integer value.
SPLIT_CHUNK_SIZE=100

# Model / training config
# Base pretrained model (HuggingFace model ID or local path) to fine-tune.
MODEL_NAME=indobenchmark/indobert-base-p1

# Fraction of the dataset to reserve for testing (float between 0 and 1).
TEST_SIZE=0.2

# Random seed for reproducible train/test splits (integer).
RANDOM_STATE=42

# Maximum token length for tokenizer/truncation (integer).
MAX_LENGTH=128

# Output / logging
# Directory where the Trainer will save intermediate checkpoints.
OUTPUT_DIR=./checkpoints/sentiment-indobert

# Directory for TensorBoard / Trainer logs.
LOG_DIR=./logs

# Directory where the final fine-tuned model and tokenizer will be saved.
MODEL_SAVE_DIR=./models/sentiment-indobert

# Optimization / hyperparameters 
# Learning rate for the optimizer (float).
LEARNING_RATE=5e-5

# Training batch size per device (integer).
TRAIN_BATCH_SIZE=16

# Evaluation batch size per device (integer).
EVAL_BATCH_SIZE=64

# Number of training epochs (integer).
NUM_TRAIN_EPOCHS=3

# Weight decay for optimizer regularization (float).
WEIGHT_DECAY=0.01

# Automatic labeling config
# OpenAI-compatible API endpoint and key for auto-labeling (if used).
# Set these if you want to use the auto-labeling step with an OpenAI-compatible API.
CLIENT_BASE_URL=https://api.openai.com/v1

# Replace with your actual API key. Keep this secret!
CLIENT_API_KEY=your-api-key-here

# The model to use for auto-labeling. This should be compatible with the API you're using.
MODEL=gpt-5.5
